# Copy this file to `.env` and fill in your own API keys.
# None of these keys are committed to the repo.

# Anthropic Claude — used for theme interpretation, metadata, ads briefs,
# community/Reddit/Discord drafts, and SEO v2.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — used for reference-track analysis and Shorts segment picking.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs — used to generate the actual audio for each layer (Music v1 + SFX v2).
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# xAI Grok — used for visual scene image generation (the YouTube thumbnail).
# Optional: leave blank to disable the Visuals tab.
# Get one at https://console.x.ai/
XAI_API_KEY=

# Optional: override Gemini analysis chunk length (seconds).
# GEMINI_MAX_ANALYSIS_SEC=600
